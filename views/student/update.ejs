<h2>Update Student</h2>

<form action="/students/<%= student.id %>" method="POST">
    <table>
        <tr>
            <td><label>Admission Number</label></td>
            <td><input type="text" name="admission_number" value="<%= student.admission_number %>"></td>
        </tr>
        <tr>
            <td><label>First Name</label></td>
            <td><input type="text" name="first_name" value="<%= student.first_name %>"></td>
        </tr>
        <tr>
            <td><label>Last Name</label></td>
            <td><input type="text" name="last_name" value="<%= student.last_name %>"></td>
        </tr>
    </table>
    <button type="submit">Update</button>
</form>
